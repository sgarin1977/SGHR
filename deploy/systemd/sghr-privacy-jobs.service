[Unit]
Description=SGHR Privacy DSR Jobs
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=sghr
Group=sghr
WorkingDirectory=/opt/sghr
EnvironmentFile=/opt/sghr/.env
Environment=PYTHONPATH=/opt/sghr
ExecStart=/opt/sghr/venv/bin/python /opt/sghr/scripts/process_privacy_jobs.py --limit 20 --export-dir /opt/sghr/exports/data_subject_requests

# Basic hardening
NoNewPrivileges=true
PrivateTmp=true
